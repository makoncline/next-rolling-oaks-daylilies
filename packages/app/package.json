    "date-fns": "^4.1.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-responsive-carousel": "^3.2.23",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
